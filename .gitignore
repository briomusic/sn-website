# Ignore hidden files and directories (files/folders starting with .)
.*

# Allow .gitignore itself to be tracked
!.gitignore

# Ignore specific hidden files
.DS_Store
Thumbs.db

# Dependency / build artifacts
node_modules/
dist/
build/

# GitHub Actions sync state
.ftp-deploy-sync-state.json

# Local environment / secrets
.env
*.local